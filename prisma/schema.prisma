datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------
// Auth & RBAC
// ---------------------------------------------------------

model User {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  passwordHash   String
  status         String    @default("ACTIVE") // ACTIVE, INACTIVE
  
  departmentId   String?
  department     Department? @relation("UserDepartment", fields: [departmentId], references: [id])
  
  // A user can be the head of a department
  headedDepartment Department? @relation("DepartmentHead")

  roleId         String
  role           Role        @relation(fields: [roleId], references: [id])

  sessions       Session[]
  refreshTokens  RefreshToken[]

  // Workflows
  allocations    Allocation[] @relation("AllocatedUser")
  transfersFrom  TransferRequest[] @relation("TransferFrom")
  transfersTo    TransferRequest[] @relation("TransferTo")
  bookings       Booking[]
  
  // Audits
  auditAssignments AuditAssignment[]

  // Audit Fields
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // ADMIN, ASSET_MANAGER, DEPARTMENT_HEAD, EMPLOYEE
  description String?
  
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., ASSET_CREATE, ASSET_VIEW
  
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])
  
  @@id([roleId, permissionId])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
}

model RefreshToken {
  id           String   @id @default(uuid())
  token        String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------
// Organization Setup
// ---------------------------------------------------------

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  status      String   @default("ACTIVE") // ACTIVE, INACTIVE
  
  headId      String?  @unique
  head        User?    @relation("DepartmentHead", fields: [headId], references: [id])
  
  parentId    String?
  parent      Department? @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children    Department[] @relation("DepartmentHierarchy")
  
  users       User[] @relation("UserDepartment")
  assets      Asset[]
  allocations Allocation[]
}

model AssetCategory {
  id             String   @id @default(uuid())
  name           String   @unique
  customFields   Json?    // CategoryFields stored as JSON
  
  assets         Asset[]
}

// ---------------------------------------------------------
// Assets
// ---------------------------------------------------------

model Asset {
  id              String   @id @default(uuid())
  name            String
  assetTag        String   @unique
  qrCodeUrl       String?
  barcode         String?
  
  categoryId      String
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  
  acquisitionCost Float?
  purchaseDate    DateTime?
  warrantyExpiry  DateTime?
  location        String?
  
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  
  currentHolderId String?  // ID of User or Department
  vendor          String?
  condition       String?
  retirementDate  DateTime?
  
  lifecycleStatus AssetStatus @default(AVAILABLE)
  isBookable      Boolean     @default(false)
  
  version         Int         @default(1)
  
  // Relations
  allocations     Allocation[]
  transferRequests TransferRequest[]
  bookings        Booking[]
  maintenanceReqs MaintenanceRequest[]
  auditResults    AuditResult[]
  history         AssetHistory[]
  files           File[]

  createdBy       String?
  updatedBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
}

model AssetHistory {
  id          String   @id @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  
  changedBy   String
  changeType  String // e.g., STATUS_CHANGE, ALLOCATION, MAINTENANCE
  oldValue    Json?
  newValue    Json?
  
  createdAt   DateTime @default(now())
}

model File {
  id          String   @id @default(uuid())
  url         String
  fileName    String
  fileType    String   // PHOTO, DOCUMENT, INVOICE, QR_CODE
  
  assetId     String?
  asset       Asset?   @relation(fields: [assetId], references: [id])
  
  maintenanceId String?
  maintenance   MaintenanceRequest? @relation(fields: [maintenanceId], references: [id])
  
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------
// Workflows (Allocation, Transfer, Booking)
// ---------------------------------------------------------

model Allocation {
  id                  String   @id @default(uuid())
  assetId             String
  asset               Asset    @relation(fields: [assetId], references: [id])
  
  userId              String?
  user                User?    @relation("AllocatedUser", fields: [userId], references: [id])
  
  departmentId        String?
  department          Department? @relation(fields: [departmentId], references: [id])
  
  expectedReturnDate  DateTime?
  returnedAt          DateTime?
  conditionNotes      String?
  
  status              AllocationStatus @default(ACTIVE)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TransferRequest {
  id                  String   @id @default(uuid())
  assetId             String
  asset               Asset    @relation(fields: [assetId], references: [id])
  
  fromUserId          String?
  fromUser            User?    @relation("TransferFrom", fields: [fromUserId], references: [id])
  
  toUserId            String
  toUser              User     @relation("TransferTo", fields: [toUserId], references: [id])
  
  status              TransferStatus @default(PENDING)
  approvalDetails     String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Booking {
  id                  String   @id @default(uuid())
  assetId             String
  asset               Asset    @relation(fields: [assetId], references: [id])
  
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  
  startTime           DateTime
  endTime             DateTime
  
  status              BookingStatus @default(UPCOMING)
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ---------------------------------------------------------
// Maintenance Workflow
// ---------------------------------------------------------

model MaintenanceRequest {
  id                  String   @id @default(uuid())
  assetId             String
  asset               Asset    @relation(fields: [assetId], references: [id])
  
  reportedById        String
  technicianId        String?
  approvalById        String?
  
  issue               String
  priority            String   @default("MEDIUM")
  
  status              MaintenanceStatus @default(PENDING)
  
  approvedAt          DateTime?
  resolvedAt          DateTime?
  comments            String?
  
  attachments         File[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ---------------------------------------------------------
// Audit Workflow
// ---------------------------------------------------------

model AuditCycle {
  id          String   @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  scope       String? // Department ID or Location
  status      String   @default("OPEN") // OPEN, CLOSED
  
  assignments AuditAssignment[]
  results     AuditResult[]
  
  createdAt   DateTime @default(now())
}

model AuditAssignment {
  id          String   @id @default(uuid())
  auditId     String
  audit       AuditCycle @relation(fields: [auditId], references: [id])
  
  auditorId   String
  auditor     User     @relation(fields: [auditorId], references: [id])
}

model AuditResult {
  id          String   @id @default(uuid())
  auditId     String
  audit       AuditCycle @relation(fields: [auditId], references: [id])
  
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id])
  
  status      String   // VERIFIED, MISSING, DAMAGED
  notes       String?
  
  createdAt   DateTime @default(now())
}

// ---------------------------------------------------------
// System & Logs
// ---------------------------------------------------------

model ActivityLog {
  id          String   @id @default(uuid())
  who         String   // User ID
  what        String   // Action (e.g., CREATED_ASSET)
  entity      String   // ASSET, USER, etc.
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  browser     String?
  
  createdAt   DateTime @default(now())
}

model Notification {
  id            String   @id @default(uuid())
  type          String   // TRANSFER, BOOKING, MAINTENANCE, SYSTEM
  priority      String   @default("LOW") // LOW, HIGH, CRITICAL
  message       String
  isRead        Boolean  @default(false)
  actionLink    String?
  
  userId        String   // Recipient
  createdBy     String?  // System or User ID
  
  referenceType String?  // e.g., ASSET, MAINTENANCE
  referenceId   String?  
  
  createdAt     DateTime @default(now())
}

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
}

// Enums
enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}
